# Copy to .env.local and fill values. NEVER commit .env.local.
# Source: PLAN 01-01 env var contract

# Supabase — find in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase service role key — SERVER-ONLY, never NEXT_PUBLIC_
# Dashboard → Project Settings → API → service_role key
SUPABASE_SECRET_KEY=sb_secret_...

# App URL — localhost for dev, Vercel URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend API key — server-only, filled in Plan 03
RESEND_API_KEY=
